<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>XboxLedControlExperiments</AssemblyName>
    <RootNamespace>XboxLedControl</RootNamespace>
    <Platforms>x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="tmp\**" />
  </ItemGroup>

  <ItemGroup>
    <!-- Shared protocol definitions from root project -->
    <Compile Include="../GipLedCommand.cs" />
  </ItemGroup>

</Project>
